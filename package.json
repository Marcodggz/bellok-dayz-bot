{
  "name": "bellok-dayz-bot",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/index.js",
    "register-commands": "node dist/register-commands.js",
    "check": "npm run lint && npm run format:check && npm test",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prestart": "npm run build",
    "preregister-commands": "npm run build"
  },
  "keywords": [
    "dayz",
    "discord-bot",
    "nitrado",
    "killfeed",
    "heatmap",
    "nodejs"
  ],
  "author": "Marco Domínguez Gil",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.12.2",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "pngjs": "^7.0.0"
  },
  "description": "A modular Discord bot that transforms DayZ PlayStation ADM logs into killfeeds, player statistics, leaderboards, and heatmaps.",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marcodggz/bellok-dayz-bot.git"
  },
  "bugs": {
    "url": "https://github.com/Marcodggz/bellok-dayz-bot/issues"
  },
  "homepage": "https://github.com/Marcodggz/bellok-dayz-bot#readme",
  "engines": {
    "node": ">=24"
  }
}
